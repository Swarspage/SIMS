# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_here_min_32_chars

# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/your_database

# Cloudinary credentials (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (for initial admin setup)
ADMIN_NAME=AdminName
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password

# Nodemailer (Gmail SMTP)
emailUser=your_email@gmail.com
emailPassword=your_gmail_app_password

# SendGrid (for email notifications)
SENDGRID_VERIFIED_SENDER=your_verified_sender@example.com
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here